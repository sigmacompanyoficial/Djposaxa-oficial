{
    "rules": {
        "admins": {
            "$uid": {
                // Only the user themselves can read/write their admin status (or admins)
                ".read": "auth != null && auth.uid === $uid",
                ".write": "auth != null && auth.uid === $uid"
            }
        },
        "users": {
            "$uid": {
                // Users can read/write their own profile
                ".read": "auth != null && auth.uid === $uid",
                ".write": "auth != null && auth.uid === $uid"
            }
        },
        "song-requests": {
            "$event_id": {
                // ONLY admins can read the list of requests (DJ Panel)
                ".read": "auth != null && (root.child('users').child(auth.uid).child('role').val() === 'admin' || root.child('users').child(auth.uid).child('role').val() === 'administrador')",
                "$request_id": {
                    // ANYONE (even unauthenticated) can CREATE a request
                    // ONLY admins can UPDATE (mark as played) or DELETE requests
                    ".write": "(!data.exists() && newData.exists()) || (data.exists() && auth != null && (root.child('users').child(auth.uid).child('role').val() === 'admin' || root.child('users').child(auth.uid).child('role').val() === 'administrador'))"
                }
            }
        },
        "analytics": {
            "ticket_clicks": {
                "$click_id": {
                    // Anyone can log a click (create only), no one can delete/modify history
                    ".write": "!data.exists() && newData.exists()"
                }
            },
            "ticket_click_count": {
                ".read": true,
                // Anyone can update the counter (needed for runTransaction)
                ".write": "newData.isNumber()"
            }
        }
    }
}